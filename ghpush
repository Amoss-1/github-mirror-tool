#!/bin/bash
# GitHub API 推送工具 - ghpush
# https://github.com/Amoss-1/github-mirror-tool
# 通过 gh api 上传文件，绕过 git push 的网络问题

set -e

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

usage() {
  echo "=== ghpush - GitHub API 推送 ==="
  echo ""
  echo "用法: ghpush <文件或目录> [仓库地址] [提交信息]"
  echo ""
  echo "示例:"
  echo "  ghpush README.md                          # 上传单个文件到当前仓库"
  echo "  ghpush .                                  # 上传整个目录"
  echo "  ghpush src/ Amoss-1/my-repo               # 上传目录到指定仓库"
  echo "  ghpush main.py user/repo 'feat: 新功能'   # 带自定义提交信息"
  echo ""
  echo "前提: 已安装 gh CLI 并登录（gh auth login）"
  echo "适用场景: git push 连不上 GitHub 时，通过 API 上传文件"
  exit 0
}

# 检查 gh 是否可用
check_gh() {
  if ! command -v gh &>/dev/null; then
    # Windows 常见路径
    if [ -f "/c/Program Files/GitHub CLI/gh.exe" ]; then
      export PATH="/c/Program Files/GitHub CLI:$PATH"
    else
      echo -e "${RED}错误: 未找到 gh CLI，请先安装: https://cli.github.com${NC}"
      exit 1
    fi
  fi

  if ! gh auth status &>/dev/null; then
    echo -e "${RED}错误: gh 未登录，请先运行: gh auth login${NC}"
    exit 1
  fi
}

# 获取当前仓库信息
get_repo() {
  local repo
  repo=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null)
  if [ -n "$repo" ]; then
    echo "$repo"
  fi
}

# 上传单个文件
upload_file() {
  local file="$1"
  local repo="$2"
  local message="$3"
  local rel_path="$4"

  # base64 编码
  local content
  content=$(base64 -w0 "$file" 2>/dev/null || base64 "$file" 2>/dev/null)

  # 检查文件是否已存在（获取 sha 用于更新）
  local sha
  sha=$(gh api "repos/${repo}/contents/${rel_path}" -q .sha 2>/dev/null || echo "")

  # 构建 API 参数
  local api_args=(-X PUT -f message="$message" -f content="$content")
  if [ -n "$sha" ]; then
    api_args+=(-f sha="$sha")
  fi

  # 上传
  if gh api "repos/${repo}/contents/${rel_path}" "${api_args[@]}" &>/dev/null; then
    echo -e "  ${GREEN}OK${NC} $rel_path"
    return 0
  else
    echo -e "  ${RED}FAIL${NC} $rel_path"
    return 1
  fi
}

# 上传目录
upload_dir() {
  local dir="$1"
  local repo="$2"
  local message="$3"
  local base_dir="$4"

  local count=0
  local fail=0

  # 遍历所有文件（跳过 .git 和隐藏文件）
  while IFS= read -r -d '' file; do
    local rel_path="${file#$base_dir/}"

    # 跳过 .git 目录和二进制文件
    if [[ "$rel_path" == .git* ]]; then
      continue
    fi

    # 跳过过大的文件（> 1MB，GitHub API 限制）
    local size
    size=$(wc -c < "$file" 2>/dev/null || echo 0)
    if [ "$size" -gt 1048576 ]; then
      echo -e "  ${YELLOW}SKIP${NC} $rel_path (文件过大，超过 1MB)"
      continue
    fi

    if upload_file "$file" "$repo" "$message" "$rel_path"; then
      ((count++))
    else
      ((fail++))
    fi
  done < <(find "$dir" -type f -print0)

  echo ""
  echo "完成: $count 个文件上传成功, $fail 个失败"
}

# 主流程
[ -z "$1" ] && usage

# --help
[ "$1" = "--help" ] || [ "$1" = "-h" ] && usage

check_gh

target="$1"
repo="$2"
message="${3:-update: $(date +%Y-%m-%d\ %H:%M)}"

# 自动检测仓库
if [ -z "$repo" ]; then
  repo=$(get_repo)
  if [ -z "$repo" ]; then
    echo -e "${RED}错误: 无法检测仓库，请指定: ghpush <文件> <用户名/仓库名>${NC}"
    exit 1
  fi
fi

echo "目标仓库: $repo"
echo "提交信息: $message"
echo ""

if [ -f "$target" ]; then
  # 单个文件
  filename=$(basename "$target")
  upload_file "$target" "$repo" "$message" "$filename"
elif [ -d "$target" ]; then
  # 目录
  upload_dir "$target" "$repo" "$message" "$target"
else
  echo -e "${RED}错误: 找不到 $target${NC}"
  exit 1
fi
